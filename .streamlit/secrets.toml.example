# Copy to .streamlit/secrets.toml (gitignored) for LOCAL live data, OR paste
# the same line(s) into Streamlit Cloud -> app -> Settings -> Secrets.
#
# Preferred: API-Football (api-sports.io) — has the live 2026 World Cup draw.
API_FOOTBALL_KEY = "your_api_football_key_here"

# If you use API-Football via RapidAPI instead of direct, also set:
# API_FOOTBALL_HOST = "api-football-v1.p.rapidapi.com"

# Optional fallback provider: football-data.org
# FOOTBALL_DATA_TOKEN = "your_football_data_token_here"
